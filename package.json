{
  "name": "eventpulse",
  "version": "1.0.0",
  "private": true,
  "description": "EventPulse — Real-time Event Management Platform",
  "author": "EventPulse Team",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "docker:dev": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "seed:postgres": "docker exec -i eventpulse-postgres psql -U eventpulse -d eventpulse < infra/postgres/seed.sql",
    "seed:mongo": "docker exec -i eventpulse-mongodb mongosh -u eventpulse -p eventpulse_secret --authenticationDatabase admin < infra/mongo/seed-demo.js",
    "seed": "npm run seed:postgres && npm run seed:mongo"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@sqltools/formatter": "^1.2.5",
    "ansis": "^4.2.0",
    "app-root-path": "^3.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "sha.js": "^2.4.12",
    "sql-highlight": "^6.1.0"
  }
}
