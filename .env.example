# ========================================
# EventPulse Environment Variables
# ========================================

# ── General ──
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eventpulse
POSTGRES_USER=eventpulse
POSTGRES_PASSWORD=changeme_postgres

# ── MongoDB ──
MONGO_URI=mongodb://localhost:27017
MONGO_DB_CHAT=eventpulse_chat
MONGO_DB_NOTIFICATIONS=eventpulse_notifications
MONGO_DB_ANALYTICS=eventpulse_analytics

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ── Kafka ──
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=eventpulse

# ── JWT ──
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── MinIO / S3 ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eventpulse

# ── Email (SMTP) ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ── Frontend ──
CLIENT_URL=http://localhost:5173

# ── Service Ports ──
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
EVENT_SERVICE_PORT=3002
TICKET_SERVICE_PORT=3003
CHAT_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
